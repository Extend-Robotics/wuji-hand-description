<launch>
  <arg name="hand" default="left"/>
  <arg name="gui" default="true"/>

  <param name="robot_description" textfile="$(find wuji_hand_description)/urdf/$(arg hand)-ros.urdf"/>

  <node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui"/>
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"/>
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find wuji_hand_description)/rviz/$(arg hand).rviz" required="true"/>
</launch>
